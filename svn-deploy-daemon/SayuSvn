sub showlasterrors {
    my ($input) = @_;
    our %parameters = ();
    our (@pairs) = split("&",$input);
    for ($i = 0; $i < scalar(@pairs); $i++) {
	my ($key,$value) = split("=",$pairs[$i]);
	$parameters{$key} = $value;
	$parameters{$key} =~ s/(\r)|(\n)//g;
    }
    my $rc = &check_rights($parameters{"username"},$parameters{"password"},"shlasterr");
    if ($rc eq "+OK Accepted") {
	my $http_log = "";
	my $https_log = "";
	if (-f "/mnt/drive2/logs/" . ($parameters{"repository"}) . "/error.log") { $http_log = "/mnt/drive2/logs/" . ($parameters{"repository"}) . "/error.log"; }
	if (-f "/mnt/drive2/logs/" . ($parameters{"repository"}) . "/ssl_error.log") { $https_log = "/mnt/drive2/logs/" . ($parameters{"repository"}) . "/ssl_error.log"; }
	if (length($http_log) || length($https_log)) {
	    if (!length($parameters{"start_date_time"})) {
		my $cmd = "cat $http_log $https_log";
		my $response = "";
		my @error_log = ();
		chomp(@error_log = `$cmd`);
		if (scalar(@error_log)) {
		    if (scalar(@error_log) >= 50) {
			my $arr_size = scalar(@error_log);
			for (my $j = $arr_size - 51; $j <= $arr_size - 1; $j++) {
			    $response .= $error_log[$j] . "\n";
			}
		    }
		    else {
			for (my $j = 0; $j < scalar(@error_log); $j++) {
			    $response .= $error_log[$j] . "\n";
			}
		    }
		    $response = encode_base64($response);
		    return "+OK Last Errors: $response\n";
		}
		else {
		    return "-ERR The error log is empty\n";
		}
	    }
	    else {
		$response = &log_after_ts($parameters{"start_date_time"}, $parameters{"repository"});
		if (!length($response)) {
		    return "-ERR The error log is empty\n";
		}
		else {
		    $response = encode_base64($response);
		    return "+OK Last Errors: $response\n";
		}
	    }
	}
	else {
	    return "-ERR No logs found\n";
	}
    }
    else { return "-ERR Access denied\n"; }
}

