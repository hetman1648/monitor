	}
	chdir("/");
	if ($svnresp =~ /revision/) {
	    return "+OK Updates: $svnresp\n";
	}
	else {
	    return "-ERR Repository show updates error. Check if \"svnserve -d\" is ran\n";
	}
    }
    else { return "-ERR Access denied\n"; }
}

