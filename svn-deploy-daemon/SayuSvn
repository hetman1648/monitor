sub log_after_ts() {
    my %mon2num = qw(Jan 0  Feb 1  Mar 2  Apr 3  May 4  Jun 5  Jul 6  Aug 7  Sep 8  Oct 9 Nov 10 Dec 11);
    my ($timestamp, $repository) = @_;
    my $log_content = "";
    my @output = ();
    my @ssl_output = ();
    my @clean_output = ();
    my $i = 0;
    my $j = 0;
    if (-f "/mnt/drive2/logs/$repository/ssl_error.log") {
	open(F, "/mnt/drive2/logs/$repository/ssl_error.log");
	chomp(@ssl_output = <F>);
	close(F);
	for ($i = 0; $i < scalar(@ssl_output); $i++) {
	    $ssl_output[$i] =~ /^\[([^\]]+)\]/;
	    my ($wday, $mon, $mday, $hour, $min, $sec, $msec, $year) = split(/[\s.:]+/, $1);
	    my $time = timelocal($sec, $min, $hour, $mday, $mon2num{substr($mon, 0, 3)}, $year);
	    if ($time >= $timestamp) {
		if ($j < 50) {
		    $clean_output[$j] = $ssl_output[$i];
		    $j++;
		}
	    }
	}
    }
    if ($j < 50) {
	if (-f "/mnt/drive2/logs/$repository/error.log") {
	    open(F, "/mnt/drive2/logs/$repository/error.log");
	    chomp(@output = <F>);
	    close(F);
	}
	for ($i = 0; $i < scalar(@output); $i++) {
	    $output[$i] =~ /^\[([^\]]+)\]/;
	    my ($wday, $mon, $mday, $hour, $min, $sec, $msec, $year) = split(/[\s.:]+/, $1);
	    my $time = timelocal($sec, $min, $hour, $mday, $mon2num{substr($mon, 0, 3)}, $year);
	    if ($time >= $timestamp) {
		if ($j < 50) {
		    $clean_output[$j] = $output[$i];
		    $j++;
		}
	    }
	}
    }
    $log_content = join("\n", @clean_output);
    return $log_content;
}

sub err_after_ts() {
    my %mon2num = qw(Jan 0  Feb 1  Mar 2  Apr 3  May 4  Jun 5  Jul 6  Aug 7  Sep 8  Oct 9 Nov 10 Dec 11);
    my ($timestamp, $cmd) = @_;
    my @clean_output = ();
    my @output = `$cmd`;
    chomp(@output);
    my $i = 0;
    my $j = 0;
    for ($i = 0; $i < scalar(@output); $i++) {
	$output[$i] =~ /^\[([^\]]+)\]/;
	my ($wday, $mon, $mday, $hour, $min, $sec, $msec, $year) = split(/[\s.:]+/, $1);
	my $time = timelocal($sec, $min, $hour, $mday, $mon2num{substr($mon, 0, 3)}, $year);
	if ($time >= $timestamp) {
	    if ($j < 50) {
		$clean_output[$j] = $output[$i];
		$j++;
	    }
	}
    }

    return @clean_output;
}
