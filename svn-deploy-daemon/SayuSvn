#!/usr/bin/perl

use POSIX;
use POSIX ":sys_wait_h";
use File::Basename;
use Socket;
use IO::Handle;
use Sys::Syslog qw( :DEFAULT setlogsock);
use Digest::MD5 qw(md5_hex);
use Fcntl qw(:flock);
use DBI;
use MIME::Base64 qw(encode_base64);
use Time::Local;

@children = ();
sub REAPER {
    $SIG{CHLD} = \&REAPER;
    for ($i = 0; $i < scalar(@children); $i++) {
	waitpid($children[$i],0);
	delete $children[$i];
    }
}
$SIG{CHLD} = \&REAPER;

$CONFIG = "/etc/sayu-svn/sayu-svn.conf";
%cfg = ();
open(CONF,"$CONFIG");
chomp(@data = <CONF>);
close(CONF);

for ($i = 0; $i < scalar(@data); $i++) {
    $data[$i] =~ s/\ //g;
    my ($key,$value) = split("=",$data[$i]);
    $cfg{"$key"} = $value;
}

if ($cfg{"type"} eq "UNIX") {
    if (-e $cfg{"socket"}) {
	setlogsock('unix');
	openlog($0,'pid','SayuSvn');
	syslog('err', ($cfg{"socket"}) . " already exists. Exit.");
	closelog();
	exit(1);
    }
}

POSIX::setsid or die "setsid: $!";

chdir("/");
umask 0022;

foreach (0 .. (POSIX::sysconf (&POSIX::_SC_OPEN_MAX) || 1024)) { 
    POSIX::close $_ 
}

open(STDIN, "</dev/null");
open(STDOUT, ">/dev/null");
open(STDERR, ">&STDOUT");

my $pid = fork();

if ($pid < 0) {
    die "fork: $!";
} elsif ($pid) {
    if (!-e $cfg{"socket"}) {
	if (!-d dirname($cfg{"pid_file"})) {
	    system("mkdir -p " . (dirname($cfg{"pid_file"})));
	}
	open(PID_FILE,">" . ($cfg{"pid_file"}));
	print PID_FILE "$pid";
	close(PID_FILE);
    }
    exit(0);
} elsif (!$pid) {
}

setsid();
setpgrp(0,0);

if ($cfg{"type"} eq "UNIX") {
    socket(SAYUSVN,PF_UNIX,SOCK_STREAM,0);
    unlink($cfg{"socket"});
    bind(SAYUSVN,sockaddr_un($cfg{"socket"}));
    chmod($cfg{"socket"},int($cfg{"socket_umask"}));
    listen(SAYUSVN,100);
}
if ($cfg{"type"} eq "TCP") {
    socket(SAYUSVN, PF_INET, SOCK_STREAM, getprotobyname("tcp"));
    setsockopt(SAYUSVN, SOL_SOCKET, SO_REUSEADDR, 1);
    bind(SAYUSVN, pack_sockaddr_in($cfg{"socket"}, inet_aton("77.68.48.248")));
    listen(SAYUSVN, 100);
}

while (1) {
    while (accept(CLIENT, SAYUSVN)) {
	setsockopt(CLIENT, SOL_SOCKET, SO_SNDTIMEO, pack('L!L!', 15, 0));
	setsockopt(CLIENT, SOL_SOCKET, SO_RCVTIMEO, pack('L!L!', 15, 0));
	$svnpid = fork();
	if ($svnpid) {
	    push(@children,$svnpid);
	    close(CLIENT);  # parent copy of the client fd: without this, clients reading to EOF hang until the next accept()
	    next;
	}
	if (!$svnpid) {
	    &do_threaded();
	    exit;
	}
    }
}

sub do_threaded {
    our %parameters = ();
    CLIENT->autoflush(1);
    print CLIENT "SayuSvn daemon ready...\n";
    my $instructions = <CLIENT>;
    &log_message("Got instructions: $instructions");
    our (@pairs) = split("&",$instructions);
    my $i = 0;
    for ($i = 0; $i < scalar(@pairs); $i++) {
	my ($key,$value) = split("=",$pairs[$i]);
	$parameters{$key} = $value;
	$parameters{$key} =~ s/(\r)|(\n)//g;
    }
    if ($parameters{"action"} eq "createuser") { 
	print CLIENT &createuser($instructions);
    }
    if ($parameters{"action"} eq "passwd") {
	print CLIENT &passwd($instructions);
    }
    if ($parameters{"action"} eq "show") {
	print CLIENT &show($instructions);
    }
    if ($parameters{"action"} eq "checkout") {
	print CLIENT &checkout($instructions);
    }
    if ($parameters{"action"} eq "state") {
	print CLIENT &state($instructions);
    }
    if ($parameters{"action"} eq "shperm") {
	print CLIENT &shperm($instructions);
    }
    if ($parameters{"action"} eq "shmyperm") {
	print CLIENT &shmyperm($instructions);
    }
    if ($parameters{"action"} eq "mypasswd") {
	print CLIENT &mypasswd($instructions);
    }
    if ($parameters{"action"} eq "showupdates") {
	print CLIENT &showupdates($instructions);
    }
    if ($parameters{"action"} eq "showusers") {
	print CLIENT &showusers($instructions);
    }
    if ($parameters{"action"} eq "shlasterr") {
	print CLIENT &showlasterrors($instructions);
    }
    if ($parameters{"action"} eq "shcriterr") {
	print CLIENT &showcriterrors($instructions);
    }
    if ($parameters{"action"} eq "showcrons") {
	print CLIENT &showcrons($instructions);
    }
    if ($parameters{"action"} eq "shdbbackup") {
	print CLIENT &showdbbackups($instructions);
    }
    close(CLIENT);
}

sub log_message {
    my ($message) = @_;
    setlogsock('unix');
    openlog('SayuSvn', 'pid', 'SayuSvn');
    syslog('info', $message);
    closelog();
}

sub createuser {
    my ($input) = @_;
    our %parameters = ();
    our (@pairs) = split("&",$input);
    for ($i = 0; $i < scalar(@pairs); $i++) {
	my ($key,$value) = split("=",$pairs[$i]);
	$parameters{$key} = $value;
	$parameters{$key} =~ s/(\r)|(\n)//g;
    }
    my $rc = &check_rights($parameters{"username"},$parameters{"password"},"createuser");
    if ($rc eq "+OK Accepted") {
	our @ret = ();
	my $cmd = "cat " . ($cfg{"passwd_file"}) . "| grep ^" . ($parameters{"newuser"}) . ":";
	chomp(@ret = `$cmd`);
	if (scalar(@ret)) {
	    return "-ERR User \"" . ($parameters{"newuser"}) . "\" already exists\n";
	}
	$cmd = "cat " . ($cfg{"passwd_file"}) . "| grep :subdomain=" . ($parameters{"subdomain"}) . ":";
	chomp(@ret = `$cmd`);
	if (scalar(@ret)) {
	    return "-ERR Subdomain \"" . ($parameters{"subdomain"}) . "\" already exists\n";
	}
	if (length($parameters{"newuser"}) < 3) {
	    return "-ERR Username for new user must include more than 2 symbols\n";
	}
	if ($parameters{"newuser"} =~ /[^a-zA-Z0-9_]+/) {
	    return "-ERR Username includes invalid symbol(s)\n";
	}
	if (length($parameters{"newpassword"}) < 6) {
	    return "-ERR Password for new user must include more than 6 symbols\n";
	}
	if (length($parameters{"subdomain"}) < 2) {
	    return "-ERR Invalid subdomain received\n";
	}
	if ($parameters{"subdomain"} =~ /[^a-z0-9]+/) {
	    return "-ERR Subdomain includes invalid symbol(s)\n";
	}
	if (($parameters{"usertype"} ne "admin") && ($parameters{"usertype"} ne "developer")) {
	    return "-ERR Invalid usertype\n";
	}
	my $waiting = 0;
	open(F,">>" . ($cfg{"passwd_file"}));
	while (!flock(F,2)) {
	    sleep(1);
	    $waiting++;
	    if ($waiting > 120) {
		return "-ERR Can't lock svn passwd file\n";
	    }
	}
	if ($parameters{"usertype"} eq "admin") {
	    print F "" . ($parameters{"newuser"}) . ":" . (md5_hex($parameters{"newpassword"})) . ":subdomain=" . ($parameters{"subdomain"}) . ":createuser=y:passwd=y:checkout=y:show=y:state=y:shperm=y:shmyperm=y:mypasswd=y:showupdates=y:shlasterr=y:shcriterr=y:showcrons=y\n";
	}
	if ($parameters{"usertype"} eq "developer") {
	    print F "" . ($parameters{"newuser"}) . ":" . (md5_hex($parameters{"newpassword"})) . ":subdomain=" . ($parameters{"subdomain"}) . ":createuser=n:passwd=n:checkout=y:show=y:state=y:shperm=n:shmyperm=y:mypasswd=y:showupdates=y:shlasterr=y:shcriterr=y:showcrons=y\n";
	}
	close(F);
	$waiting = 0;
	open(F,">>" . ($cfg{"svn_users_file"}));
	while (!flock(F,2)) {
	    sleep(1);
	    $waiting++;
	    if ($waiting > 120) {
		return "-ERR Can't lock svn users file\n";
	    }
	}
	print F ($parameters{"newuser"}) . " = " . ($parameters{"newpassword"}) . "\n";
	close(F);
	return "+OK User created\n";
    }
    else { return "-ERR Access denied\n"; }
}

sub passwd {
    my ($input) = @_;
    our %parameters = ();
    our (@pairs) = split("&",$input);
    for ($i = 0; $i < scalar(@pairs); $i++) {
	my ($key,$value) = split("=",$pairs[$i]);
	$parameters{$key} = $value;
	$parameters{$key} =~ s/(\r)|(\n)//g;
    }
    my $rc = &check_rights($parameters{"username"},$parameters{"password"},"passwd");
    if ($rc eq "+OK Accepted") {
	our @ret = ();
	my $cmd = "cat " . ($cfg{"passwd_file"}) . " | grep ^" . ($parameters{"chusername"}) . ":";
	chomp(@ret = `$cmd`);
	if (!scalar(@ret)) {
	    return "-ERR User \"" . ($parameters{"chusername"}) . "\" doesn't exists\n";
	}
	if (length($parameters{"chpassword"}) < 6) {
	    return "-ERR Password must include more than 6 symbols\n";
	}
	our @passwd_content = ();
	open(F,$cfg{"passwd_file"});
	chomp(@passwd_content = <F>);
	close(F);
	my $waiting = 0;
	open(F,">" . ($cfg{"passwd_file"}));
	while (!flock(F,2)) {
	    sleep(1);
	    $waiting++;
	    if ($waiting > 120) {
		return "-ERR Can't lock svn passwd file\n";
	    }
	}
	my $i = 0;
	for ($i = 0; $i < scalar(@passwd_content); $i++) {
	    if ($passwd_content[$i] eq $ret[0]) {
		our @chunks = split(":",$ret[0]);
		print F ($chunks[0]) . ":" . (md5_hex($parameters{"chpassword"}));
		for ($j = 2; $j < scalar(@chunks); $j++) {
		    print F ":" . ($chunks[$j]);
		}
		print F "\n";
	    }
	    else {
		print F $passwd_content[$i] . "\n";
	    }
	}
	close(F);

	$cmd = "cat " . ($cfg{"svn_users_file"}) . " | grep '^" . ($parameters{"chusername"}) . " ='";
	chomp(@ret = `$cmd`);
	@passwd_content = ();
	open(F,$cfg{"svn_users_file"});
	chomp(@passwd_content = <F>);
	close(F);
	my $waiting = 0;
	open(F,">" . ($cfg{"svn_users_file"}));
	while (!flock(F,2)) {
	    sleep(1);
	    $waiting++;
	    if ($waiting > 120) {
		return "-ERR Can't lock svn users file\n";
	    }
	}
	my $i = 0;
	for ($i = 0; $i < scalar(@passwd_content); $i++) {
	    if ($passwd_content[$i] eq $ret[0]) {
		our @chunks = split("=",$ret[0]);
		print F ($chunks[0]) . "= " . ($parameters{"chpassword"}) . "\n";
	    }
	    else {
		print F $passwd_content[$i] . "\n";
	    }
	}
	close(F);
	return "+OK Password changed\n";
    }
    else { return "-ERR Access denied\n"; }
}

