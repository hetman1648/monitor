sub checkout {
    my ($input) = @_;
    our %parameters = ();
    our (@pairs) = split("&",$input);
    for ($i = 0; $i < scalar(@pairs); $i++) {
	my ($key,$value) = split("=",$pairs[$i]);
	$parameters{$key} = $value;
	$parameters{$key} =~ s/(\r)|(\n)//g;
    }
    my $rc = &check_rights($parameters{"username"},$parameters{"password"},"checkout");
    if ($rc eq "+OK Accepted") {
	if (length($parameters{"path"})) {
	    if (-d $cfg{"clients_root"} . "/" . $parameters{"repository"} . "/" . $parameters{"path"}) {
		chdir($cfg{"clients_root"} . "/" . $parameters{"repository"} . "/" . $parameters{"path"});
	    }
	    else {
		return "-ERR Invalid PATH specified: " . ($cfg{"clients_root"}) . "/" . ($parameters{"repository"}) . "/" . ($parameters{"path"});
	    }
	}
	else {
	    chdir($cfg{"clients_root"} . "/" . $parameters{"repository"});
	}
	my $cmd = "export LC_ALL=en_US.UTF-8; svn update --non-interactive --trust-server-cert --no-auth-cache --username " . ($parameters{"username"}) . " --password " . ($parameters{"password"}) . " --force";
	my $svnresponse = "";
	$svnresponse = `$cmd`;
	chdir("/");
	my $target = ($cfg{"clients_root"}) . "/" . ($parameters{"repository"});
	my $owner = (getpwuid((stat($target))[4]))[0];
	# svn ran as root; hand the tree back to the working-copy owner (the site user).
	if (defined($owner) && $owner ne "" && $owner ne "root") { system("chown -R " . $owner . ":" . $owner . " " . $target . " &"); }
	return "+OK Checkout complete\n";
    }
    else { return "-ERR Access denied\n"; }
}

